// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PHARMACIST
}

enum ProfessionalCategory {
  FULL_TIME_PHARMACIST
  LOCUM_PHARMACIST
  PHARMACIST_INTERN
  PHARMACY_TECHNICIAN
}

enum VerificationStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  REJECTED
}

enum JobType {
  FULL_TIME
  CONTRACT
  LOCUM
  INTERNSHIP
}

enum MatchStatus {
  PENDING
  ACCEPTED_BY_PHARMACIST
  REJECTED_BY_PHARMACIST
  REJECTED_BY_COMPANY
  HIRED
  CLOSED
}

enum ShiftStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  ASSIGNED
  DECLINED
}

enum PayerType {
  PHARMACIST
  COMPANY
}

enum PaymentStatus {
  DUE
  PAID
  WAIVED
  DISPUTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole          @default(PHARMACIST)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  pharmacist   PharmacistProfile?
  adminNotes   AdminNote[]       @relation("AdminNotesByAdmin")
  opportunitiesCreated Opportunity[] @relation("OpportunityCreatedByAdmin")
  matchesCreated Match[]         @relation("MatchCreatedByAdmin")
  shiftsCreated LocumShift[]     @relation("LocumShiftCreatedByAdmin")
  notifications Notification[]
}

model PharmacistProfile {
  id                    String               @id @default(cuid())
  userId                 String               @unique
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category               ProfessionalCategory
  lagosArea              String
  yearsOfExperience      Int                  @default(0)
  qualification          String
  licenseNumber          String?
  currentEmployment      String?
  preferredJobType       JobType
  availability           String?
  preferredSalaryMin     Int?
  preferredSalaryMax     Int?
  preferredWorkArea      String?
  summary                String?
  cvUrl                  String?
  verificationStatus     VerificationStatus   @default(DRAFT)
  verificationReviewedAt DateTime?
  verificationReason     String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  documents              CredentialDocument[]
  matches                Match[]
  locumApplications      LocumApplication[]
}

model CredentialDocument {
  id          String            @id @default(cuid())
  profileId   String
  profile     PharmacistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label       String
  fileUrl     String
  uploadedAt  DateTime          @default(now())
}

model Opportunity {
  id                   String                @id @default(cuid())
  title                String
  companyName          String
  companyContact       String?
  location             String
  jobType              JobType
  category             ProfessionalCategory
  salaryMin            Int?
  salaryMax            Int?
  requirements         String
  urgency              String?
  isCompanyHidden      Boolean               @default(true)
  sourceChannel        String                @default("WHATSAPP")
  createdByAdminId     String
  createdByAdmin       User                  @relation("OpportunityCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  matches              Match[]
  notes                AdminNote[]
}

model Match {
  id                   String            @id @default(cuid())
  opportunityId        String
  pharmacistProfileId  String
  status               MatchStatus       @default(PENDING)
  adminNotes           String?
  offeredAt            DateTime          @default(now())
  decidedAt            DateTime?
  createdByAdminId     String
  createdByAdmin       User              @relation("MatchCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  opportunity          Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  pharmacistProfile    PharmacistProfile @relation(fields: [pharmacistProfileId], references: [id], onDelete: Cascade)
  payments             PaymentRecord[]

  @@unique([opportunityId, pharmacistProfileId])
}

model LocumShift {
  id                   String               @id @default(cuid())
  title                String
  companyName          String
  lagosArea            String
  date                 DateTime
  startTime            String
  endTime              String
  payNaira             Int
  requirements         String
  status               ShiftStatus          @default(OPEN)
  createdByAdminId     String
  createdByAdmin       User                 @relation("LocumShiftCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  applications         LocumApplication[]
}

model LocumApplication {
  id                   String            @id @default(cuid())
  shiftId              String
  pharmacistProfileId  String
  status               ApplicationStatus @default(APPLIED)
  appliedAt            DateTime          @default(now())
  shift                LocumShift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  pharmacistProfile    PharmacistProfile @relation(fields: [pharmacistProfileId], references: [id], onDelete: Cascade)

  @@unique([shiftId, pharmacistProfileId])
}

model PaymentRecord {
  id                   String         @id @default(cuid())
  matchId              String
  payerType            PayerType
  expectedAmountNaira  Int
  status               PaymentStatus  @default(DUE)
  paidAt               DateTime?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  match                Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model AdminNote {
  id                   String       @id @default(cuid())
  adminId              String
  admin                User         @relation("AdminNotesByAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  opportunityId        String?
  opportunity          Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  text                 String
  createdAt            DateTime     @default(now())
}

model Notification {
  id              String           @id @default(cuid())
  recipientUserId String
  recipientUser   User             @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  type            NotificationType @default(INFO)
  title           String
  message         String
  linkUrl         String?
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())
  readAt          DateTime?

  @@index([recipientUserId, isRead, createdAt])
}
